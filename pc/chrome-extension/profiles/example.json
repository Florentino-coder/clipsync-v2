{
  "profile_id": "example_synthetic_v1",
  "domain_patterns": ["https://admin.example.invalid/*"],
  "order_page_url_hint": "/orders",
  "row_selector_hints": ["tr", "[class*='order']", "[class*='row']", "li", "[class*='card']"],
  "confirm_keywords": ["ยืนยัน", "confirm", "อนุมัติ", "approve", "สำเร็จ"],
  "already_confirmed_indicators": ["ยืนยันแล้ว", "confirmed", "สำเร็จแล้ว", "approved"],
  "logout_indicators": ["form[action*='login']", "input[type='password']"],
  "order_list_canary_selector": "table, [class*='order-list'], [class*='order']",
  "uses_iframe": false,
  "dry_run": true,
  "post_click_verify_timeout_ms": 15000,
  "click_wait_max_ms": 30000,
  "api": {
    "enabled": true,
    "list_pending": {
      "method": "GET",
      "url_template": "/bo/withdrawal-approve-search?skip=0&limit=50&start_date={today}&end_date={today}",
      "fields_map": {
        "order_id": "id",
        "amount": "amount",
        "account": "member_bank_account",
        "bank": "bank_information_id",
        "name": "username"
      }
    },
    "approve": {
      "method": "POST",
      "url_template": "TODO(HAR): partner approve endpoint unknown",
      "payload_template": {}
    }
  },
  "close_job_workflow": [
    {
      "action": "click",
      "target": {
        "in_row": true,
        "selector_hints": ["[class*='eye']", "svg", "button", ".eye-btn"],
        "nth_fallback": "last"
      }
    },
    {
      "action": "wait_for",
      "selector_hints": ["[class*='modal']", "[class*='popup']", "dialog"],
      "timeout_ms": 10000
    },
    { "action": "select_option", "scope": "popup", "match_text": "สำเร็จ" },
    {
      "action": "select_option",
      "scope": "popup",
      "field_hint": "ธนาคาร",
      "value_from": "slip.bank_name_th"
    },
    {
      "action": "verify_or_fill",
      "scope": "popup",
      "field_hint": "เลขบัญชี",
      "value_from": "slip.account_number"
    },
    { "action": "click", "scope": "popup", "match_text": "ยืนยัน|บันทึก|ตกลง" },
    {
      "action": "verify_result",
      "indicators": ["ปิดงานสำเร็จ", "สำเร็จ", "success"],
      "timeout_ms": 15000
    }
  ],
  "_todo": "Task 4.0 BLOCKED: replace with real customer HAR/HTML fixture + domain when partner snapshot is available. Approve URL blocked on partner HAR (see docs/OPEN_ITEMS.md)."
}
